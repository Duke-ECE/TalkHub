# ============================================================
# TalkHub Environment Template
# Copy this file to `.env` and adjust values for your machine.
# ============================================================

# ------------------------------------------------------------
# Global
# ------------------------------------------------------------
# Runtime environment label: development | staging | production
APP_ENV=development

# ------------------------------------------------------------
# Backend - HTTP Server
# ------------------------------------------------------------
# Backend API port
SERVER_PORT=8080

# ------------------------------------------------------------
# Backend - Database (PostgreSQL)
# ------------------------------------------------------------
# Preferred: set full JDBC DSN.
# If left empty, the app will compose DSN from PG_* fields below.
DB_DSN=

# PostgreSQL host/port/user/password/database
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=talkhub

# PostgreSQL SSL mode: disable | require | verify-ca | verify-full
PG_SSLMODE=disable

# Bootstrap DB used to create PG_DATABASE when missing.
PG_BOOTSTRAP_DATABASE=postgres

# Auto-create target database on startup when it does not exist.
DB_AUTO_CREATE_IF_MISSING=true

# ------------------------------------------------------------
# Backend - JWT / Auth Bootstrap
# ------------------------------------------------------------
# Change this in non-local environments.
JWT_SECRET=change-me

# Token expiration in seconds (default: 24h)
JWT_EXPIRES_SECONDS=86400

# Built-in admin account bootstrapped on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_NICKNAME=Administrator

# ------------------------------------------------------------
# Backend - Redis
# ------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------
# Backend - RabbitMQ
# ------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
# API base URL used by Vite app.
VITE_API_BASE_URL=http://localhost:8080

# WebSocket endpoint used by Vite app.
VITE_WS_URL=ws://localhost:8080/ws
